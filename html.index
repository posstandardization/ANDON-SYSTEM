<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>RTG Andon System</title>
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/xlsx/0.18.5/xlsx.full.min.js"></script>
    <style>
        :root {
            --primary: #2c3e50;
            --danger: #e74c3c;
            --success: #27ae60;
            --warning: #f1c40f;
        }
        body { font-family: sans-serif; margin: 0; background: #f4f7f6; }
        nav { background: var(--primary); padding: 1rem; display: flex; gap: 10px; justify-content: center; }
        button { padding: 12px 20px; cursor: pointer; border: none; border-radius: 4px; font-weight: bold; }
        
        /* Modals */
        .modal { display: none; position: fixed; z-index: 10; left: 0; top: 0; width: 100%; height: 100%; background: rgba(0,0,0,0.7); }
        .modal-content { background: white; margin: 5% auto; padding: 20px; width: 80%; border-radius: 8px; }
        
        /* Grid Layouts */
        .andon-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 20px; margin-top: 20px; }
        .section-box { border: 2px solid #ddd; padding: 15px; border-radius: 8px; }
        .btn-group { display: flex; flex-wrap: wrap; gap: 10px; }
        .andon-btn { width: 140px; height: 80px; font-size: 0.8rem; background: #ecf0f1; transition: 0.3s; }
        .andon-btn.active { background: var(--danger); color: white; animation: blink 1s infinite; }

        /* Control Room & Pareto */
        .view-page { display: none; padding: 20px; }
        .active-view { display: block; }
        table { width: 100%; border-collapse: collapse; background: white; }
        th, td { border: 1px solid #ddd; padding: 12px; text-align: left; }
        .blink-red { color: white; background: var(--danger); animation: blink 1s infinite; font-weight: bold; padding: 5px; }

        @keyframes blink { 0% { opacity: 1; } 50% { opacity: 0.5; } 100% { opacity: 1; } }
        
        .close-andon-bar { 
            width: 100%; margin-top: 20px; height: 60px; font-size: 1.5rem; 
            background: #95a5a6; color: white; border: none; 
        }
        .close-andon-bar.can-close { background: var(--warning); color: black; animation: blink 0.8s infinite; cursor: pointer; }
    </style>
</head>
<body>

<nav>
    <button onclick="openRTGSelection()" style="background: #3498db; color: white;">RTG</button>
    <button onclick="showPage('qcView')" style="background: #9b59b6; color: white;">QC</button>
    <button onclick="showPage('controlRoom')" style="background: #e67e22; color: white;">CONTROL ROOM VIEW</button>
    <button onclick="showPage('paretoPage')" style="background: #27ae60; color: white;">PARETO ANALYSIS</button>
</nav>

<div id="rtgModal" class="modal">
    <div class="modal-content" style="max-width: 400px; text-align: center;">
        <h2>RTG Access</h2>
        <input type="text" id="staffId" placeholder="Enter Staff ID" style="width: 100%; padding: 10px; margin-bottom: 15px;"><br>
        <select id="rtgSelect" style="width: 100%; padding: 10px; margin-bottom: 15px;"></select><br>
        <button onclick="enterAndonScreen()" style="background: var(--success); color: white; width: 100%;">OPEN ANDON SCREEN</button>
        <button onclick="closeModal('rtgModal')" style="margin-top: 10px; background: #eee;">Cancel</button>
    </div>
</div>

<div id="andonScreen" class="modal">
    <div class="modal-content">
        <h2 id="currentRtgTitle">RTG: --</h2>
        <div class="andon-grid">
            <div class="section-box">
                <h3>OPS ANDONS</h3>
                <div class="btn-group" id="opsBtns">
                    </div>
            </div>
            <div class="section-box">
                <h3>TECH ANDONS</h3>
                <div class="btn-group" id="techBtns">
                    </div>
            </div>
        </div>
        <button id="closeAndonBar" class="close-andon-bar" onclick="closeActiveAndon()">CLOSE ANDON</button>
        <button onclick="closeModal('andonScreen')" style="margin-top:10px;">Exit Screen</button>
    </div>
</div>

<div id="controlRoom" class="view-page">
    <h2>Live Control Room Monitoring</h2>
    <table>
        <thead>
            <tr>
                <th>RTG No</th>
                <th>Staff ID</th>
                <th>Andon Type</th>
                <th>Fault</th>
                <th>Timer</th>
                <th>Status</th>
            </tr>
        </thead>
        <tbody id="controlRoomBody"></tbody>
    </table>
</div>

<div id="paretoPage" class="view-page">
    <h2>Pareto Analysis & History</h2>
    <div style="background: white; padding: 15px; margin-bottom: 20px; border-radius: 8px;">
        <label>Filter Date: <input type="date" id="filterDate"></label>
        <label>RTG: <select id="filterRtg"><option value="All">All</option></select></label>
        <button onclick="exportToExcel()" style="background: #27ae60; color: white;">Download Excel</button>
    </div>
    <div style="max-width: 800px; margin: auto;">
        <canvas id="paretoChart"></canvas>
    </div>
</div>

<div id="qcView" class="view-page">
    <h2>QC View</h2>
    <p>QC specific monitoring content goes here...</p>
</div>

<script>
    // --- Data Management ---
    let activeAndons = []; // Current live issues
    let history = JSON.parse(localStorage.getItem('andonHistory')) || [];
    let selectedRtg = null;
    let selectedStaff = null;

    // Populate RTG Dropdown (33 to 128)
    const rtgDropdown = document.getElementById('rtgSelect');
    const filterRtg = document.getElementById('filterRtg');
    for(let i=33; i<=128; i++) {
        let opt = new Option(`RTG ${i}`, i);
        rtgDropdown.add(opt);
        filterRtg.add(new Option(`RTG ${i}`, i));
    }

    const opsList = ["NO TT", "NO JOB TO DO", "GANTRY", "WHEELTURN", "ACCIDENT", "CONTAINER ALIGNMENT", "OTHERS"];
    const techList = ["HOIST FAULT", "SPREADER FAULT", "TROLLEY FAULT", "GANTRY FAULT", "CONTROL/POWER", "TRIM/SKEW", "OTHER"];

    // Initialize Buttons
    function initAndonBtns() {
        const createBtns = (list, containerId, type) => {
            const container = document.getElementById(containerId);
            container.innerHTML = '';
            list.forEach(item => {
                let btn = document.createElement('button');
                btn.className = 'andon-btn';
                btn.innerText = item;
                btn.onclick = () => raiseAndon(item, type);
                container.appendChild(btn);
            });
        };
        createBtns(opsList, 'opsBtns', 'OPS');
        createBtns(techList, 'techBtns', 'TECH');
    }

    // --- Core Logic ---
    function openRTGSelection() { document.getElementById('rtgModal').style.display = 'block'; }
    function closeModal(id) { document.getElementById(id).style.display = 'none'; }

    function enterAndonScreen() {
        selectedStaff = document.getElementById('staffId').value;
        selectedRtg = rtgDropdown.value;
        if(!selectedStaff) return alert("Enter Staff ID");
        
        document.getElementById('currentRtgTitle').innerText = `RTG: ${selectedRtg} | Staff: ${selectedStaff}`;
        closeModal('rtgModal');
        document.getElementById('andonScreen').style.display = 'block';
        initAndonBtns();
        checkActiveStatus();
    }

    function raiseAndon(fault, type) {
        if(activeAndons.find(a => a.rtg === selectedRtg)) return alert("An Andon is already active for this RTG!");
        
        const newAndon = {
            rtg: selectedRtg,
            staff: selectedStaff,
            type: type,
            fault: fault,
            startTime: new Date().getTime(),
            displayTime: new Date().toLocaleString()
        };
        activeAndons.push(newAndon);
        checkActiveStatus();
        updateControlRoom();
    }

    function checkActiveStatus() {
        const active = activeAndons.find(a => a.rtg === selectedRtg);
        const bar = document.getElementById('closeAndonBar');
        if(active) {
            bar.classList.add('can-close');
            // Highlight the button that was clicked (simplified for demo)
        } else {
            bar.classList.remove('can-close');
        }
    }

    function closeActiveAndon() {
        const index = activeAndons.findIndex(a => a.rtg === selectedRtg);
        if(index === -1) return;

        const closed = activeAndons.splice(index, 1)[0];
        closed.endTime = new Date().getTime();
        closed.endDisplay = new Date().toLocaleString();
        
        history.push(closed);
        localStorage.setItem('andonHistory', JSON.stringify(history));
        
        checkActiveStatus();
        updateControlRoom();
        updatePareto();
    }

    function showPage(pageId) {
        document.querySelectorAll('.view-page').forEach(p => p.classList.remove('active-view'));
        document.getElementById(pageId).classList.add('active-view');
        if(pageId === 'controlRoom') updateControlRoom();
        if(pageId === 'paretoPage') updatePareto();
    }

    // --- Views ---
    function updateControlRoom() {
        const tbody = document.getElementById('controlRoomBody');
        tbody.innerHTML = '';
        activeAndons.forEach(a => {
            const row = tbody.insertRow();
            row.innerHTML = `
                <td>${a.rtg}</td>
                <td>${a.staff}</td>
                <td>${a.type}</td>
                <td><span class="blink-red">${a.fault}</span></td>
                <td id="timer-${a.rtg}">0s</td>
                <td>ACTIVE</td>
            `;
        });
    }

    // Live Timer Update
    setInterval(() => {
        activeAndons.forEach(a => {
            const el = document.getElementById(`timer-${a.rtg}`);
            if(el) {
                const diff = Math.floor((new Date().getTime() - a.startTime) / 1000);
                el.innerText = `${diff}s`;
            }
        });
    }, 1000);

    // --- Analytics & Export ---
    let myChart;
    function updatePareto() {
        const counts = {};
        history.forEach(h => counts[h.fault] = (counts[h.fault] || 0) + 1);
        
        const labels = Object.keys(counts).sort((a,b) => counts[b] - counts[a]);
        const data = labels.map(l => counts[l]);

        if(myChart) myChart.destroy();
        const ctx = document.getElementById('paretoChart').getContext('2d');
        myChart = new Chart(ctx, {
            type: 'bar',
            data: {
                labels: labels,
                datasets: [{ label: 'Fault Frequency', data: data, backgroundColor: '#3498db' }]
            }
        });
    }

    function exportToExcel() {
        const data = history.map(h => ({
            "RTG NO": h.rtg,
            "STAFF ID": h.staff,
            "ANDON RAISED": h.fault,
            "START TIME": h.displayTime,
            "CLOSED TIME": h.endDisplay
        }));
        const worksheet = XLSX.utils.json_to_sheet(data);
        const workbook = XLSX.utils.book_new();
        XLSX.utils.book_append_sheet(workbook, worksheet, "Andon Log");
        XLSX.writeFile(workbook, "RTG_Andon_History.xlsx");
    }

</script>

</body>
</html>
